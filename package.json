{
  "name": "science-desktop",
  "private": true,
  "version": "1.0.2",
  "description": "Science web app desktop wrapper for Windows.",
  "author": "Codex",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "powershell -NoProfile -Command \"Remove-Item -Recurse -Force dist, dist-electron -ErrorAction SilentlyContinue\"",
    "lint": "tsc --noEmit",
    "electron": "electron .",
    "build:exe": "npm run build && electron-builder build --win --publish never -c electron-builder.config.cjs",
    "build:release": "npm run build && electron-builder build --win --publish always -c electron-builder.config.cjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "express": "^4.21.2",
    "firebase": "^12.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
